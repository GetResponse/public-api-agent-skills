    "/contacts": {
      "get": {
        "operationId": "listContacts",
        "summary": "Search/list contacts",
        "description": "Find contacts by email, campaign, or other filters. Useful to check if a contact already exists.",
        "parameters": [
          {
            "name": "query[email]",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by exact email address"
          },
          {
            "name": "query[campaignId]",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by campaign ID"
          },
          {
            "name": "query[name]",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "perPage",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 100,
              "maximum": 1000
            }
          },
          {
            "name": "additionalFlags",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "customFieldValues"
              ]
            },
            "description": "Pass 'customFieldValues' to include custom field data in response"
          },
          {
            "$ref": "#/components/parameters/RequestSource"
          }
        ],
        "responses": {
          "200": {
            "description": "Array of contacts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Contact"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createContact",
        "summary": "Add a single contact to a campaign",
        "description": "Add one contact. For multiple contacts use POST /contacts/batch. If contact already exists in the campaign, this updates their data.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NewContact"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Contact accepted for processing (async operation)"
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Contact already exists in campaign"
          }
        },
        "parameters": [
          {
            "$ref": "#/components/parameters/RequestSource"
          }
        ]
      }
    },
    "/contacts/batch": {
      "post": {
        "operationId": "batchCreateContacts",
        "summary": "Import multiple contacts at once (up to 1000 per request)",
        "description": "Bulk-import contacts into a campaign. Max 1000 contacts per call. For larger sets, split into chunks of 1000 and call in parallel (respect rate limits). Custom fields must exist before using their IDs here.",
