                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "$ref": "#/components/parameters/RequestSource"
          }
        ]
      }
    },
    "/contacts/{contactId}": {
